# PLC connection
SCADA_PLC_IP=192.168.0.1
SCADA_PLC_RACK=0
SCADA_PLC_SLOT=1
SCADA_DB_GATES=13
SCADA_MOTOR_BLOCK_SIZE=2
SCADA_MOTOR_FLAGS_BYTE_OFFSET=0

# Refresh and monitor db config
SCADA_REFRESH_SECONDS=1.0
SCADA_DB_MONITOR=100
SCADA_MONITOR_STRIDE=16
SCADA_GATE_BLOCK_SIZE=1

# Comma-separated allowed origins
SCADA_CORS_ORIGINS=http://localhost:8100,http://127.0.0.1:8100
